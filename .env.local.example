# Copy to .env.local and fill in your own values.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx_or_legacy_eyJ...

# AI provider for the drawing import parser.
# Set ONE or BOTH. If both are set, AI_PROVIDER selects which to use; if
# AI_PROVIDER is unset, OpenAI is preferred when both keys exist.

# AI_PROVIDER=openai          # or "anthropic"
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Server-only secret. Do NOT prefix with NEXT_PUBLIC_.
# SUPABASE_SECRET_KEY=sb_secret_...
